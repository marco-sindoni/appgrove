# appgrove — stack di sviluppo locale (UC 0008)
# Copia in dev/.env (NON committato, #12 §7) e adatta. Mai segreti reali: qui solo
# valori fittizi per le dipendenze locali. I segreti veri vivono in SSM/Secrets su AWS.

# ── Postgres (≈ Aurora Serverless v2) — major 17 allineato a test/prod (#12 §8) ──
POSTGRES_USER=appgrove
POSTGRES_PASSWORD=appgrove_local_dev
POSTGRES_DB=appgrove
POSTGRES_PORT=5432

# ── Caddy reverse proxy (≈ API Gateway v2) ──
PROXY_HTTP_PORT=80
PROXY_HTTPS_PORT=443

# ── Mailpit (≈ SES) ──
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── MinIO (≈ S3) — credenziali locali fittizie ──
MINIO_ROOT_USER=appgrove
MINIO_ROOT_PASSWORD=appgrove_local_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── ElasticMQ (≈ SQS) ──
ELASTICMQ_PORT=9324
