{
  "name": "@appgrove/api-client",
  "version": "0.1.0",
  "description": "appgrove API client — tipi generati da OpenAPI (core) + client openapi-fetch con auth/refresh/problem+json (UC 0020)",
  "type": "module",
  "license": "UNLICENSED",
  "files": ["dist", "src"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "gen": "openapi-typescript ../../../services/core/src/main/resources/META-INF/openapi/openapi.yaml -o src/schema.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.6.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9"
  }
}
