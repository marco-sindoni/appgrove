# appgrove frontend usa TypeScript 6 (l'ultima major). Diverse librerie dichiarano ancora un
# peer OPZIONALE `typescript@^5` non aggiornato → npm (strict) lo tratta come conflitto.
# legacy-peer-deps rilassa SOLO il check dei peer in fase di install (nessun effetto a runtime).
# Follow-up tracciato (UC 0020 / _BACKLOG): rimuovere quando l'ecosistema aggiorna i peer a TS6.
legacy-peer-deps=true
