# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
*.iml
.vscode/

# --- Node / TypeScript (frontend, infra CDK) ---
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
.eslintcache
.npm/

# --- AWS CDK ---
cdk.out/
.cdk.staging/

# --- Terraform (infra/) ---
# .terraform.lock.hcl invece SI committa (versioni provider riproducibili).
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
# Zip Lambda generati da archive_file al plan/apply (il sorgente .py si committa).
infra/**/lambda/*.zip
crash.log
crash.*.log

# --- Java / Maven (services) ---
target/
*.class
!.mvn/wrapper/maven-wrapper.jar

# --- Quarkus ---
.quarkus/

# --- env / secrets ---
.env
.env.*
!.env.example
*.local

# --- local dev stack (UC 0008) ---
dev/certs/*
!dev/certs/.gitkeep

# --- auth (UC 0010): chiavi JWT locali + pid/log del processo host ---
dev/auth/
dev/.auth.pid
dev/.auth.log

# --- app-start/app-stop: pid/log dei processi host ---
dev/.run/
