#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# check — validazione statica di TUTTO il codice Terraform, SENZA toccare AWS
# (niente credenziali richieste): fmt, validate, tflint e checkov se presenti.
# È ciò che lancia anche `run-tests.sh infra` (#10 H).
# ─────────────────────────────────────────────────────────────────────────────
set -euo pipefail
source "$(dirname "${BASH_SOURCE[0]}")/_lib.sh"

usage() {
  cat <<'EOF'
Uso: check [--help]

Cosa fa (in ordine; nessuna credenziale AWS necessaria, nessuna risorsa toccata)
  1. terraform fmt -check  su tutto infra/ (formattazione canonica)
  2. terraform validate    su ogni root (bootstrap, global, envs/test, envs/prod)
                           con `init -backend=false` (scarica solo i provider,
                           cache condivisa in ~/.terraform.d/plugin-cache)
  3. terraform test        sui moduli con test (microsaas_app, observability, #10 29): plan
                           con provider AWS FINTO (mock), quindi offline
  4. tflint                se installato (lint aggiuntivo)
  5. checkov               se installato (analisi statica di sicurezza; le
                           soppressioni inline sono documentate nel codice)
  6. actionlint            se installato (lint dei workflow GitHub Actions,
                           .github/workflows/ — UC 0005)

Il `terraform plan` NON è incluso: richiede credenziali e state (→ CI, UC 0005,
oppure ./infra/scripts/plan <env> a mano).

Esempi
  ./infra/scripts/check
EOF
}
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then usage; exit 0; fi
if [ $# -gt 0 ]; then usage; die "argomento inatteso: $1"; fi

require_terraform

ROOTS=(bootstrap global envs/test envs/prod)
# Moduli con suite `terraform test` (tests/*.tftest.hcl, provider mock → offline).
TESTED_MODULES=(modules/microsaas_app modules/observability)
RC=0

info "1/6 terraform fmt -check (tutto infra/)…"
if terraform -chdir="$INFRA_DIR" fmt -check -recursive; then
  ok "fmt: formattazione canonica"
else
  warn "fmt: file non formattati (fix: terraform -chdir=infra fmt -recursive)"; RC=1
fi

info "2/6 terraform validate (init senza backend, nessuna credenziale)…"
for root in "${ROOTS[@]}"; do
  if terraform -chdir="$INFRA_DIR/$root" init -backend=false -input=false >/dev/null \
     && terraform -chdir="$INFRA_DIR/$root" validate; then
    ok "validate: $root"
  else
    warn "validate FALLITO: $root"; RC=1
  fi
done

info "3/6 terraform test (moduli, provider mock: offline)…"
for mod in "${TESTED_MODULES[@]}"; do
  if terraform -chdir="$INFRA_DIR/$mod" init -backend=false -input=false >/dev/null \
     && terraform -chdir="$INFRA_DIR/$mod" test; then
    ok "test: $mod"
  else
    warn "terraform test FALLITO: $mod"; RC=1
  fi
done

info "4/6 tflint…"
if command -v tflint >/dev/null 2>&1; then
  # Il ruleset AWS è un plugin (infra/.tflint.hcl): --init lo scarica (idempotente,
  # cache in ~/.tflint.d). Senza rete l'init fallisce → si salta tflint con warning.
  if tflint --chdir="$INFRA_DIR" --init >/dev/null 2>&1; then
    for root in "${ROOTS[@]}"; do
      if tflint --chdir="$INFRA_DIR/$root" --call-module-type=all; then
        ok "tflint: $root"
      else
        warn "tflint FALLITO: $root"; RC=1
      fi
    done
  else
    warn "tflint --init fallito (rete assente?): salto tflint."
  fi
else
  warn "tflint non installato: salto (vedi infra/README.md per l'installazione)."
fi

info "5/6 checkov…"
if command -v checkov >/dev/null 2>&1; then
  if checkov --config-file "$INFRA_DIR/.checkov.yaml" --directory "$INFRA_DIR"; then
    ok "checkov: nessun rilievo (o soppressioni documentate)"
  else
    warn "checkov FALLITO"; RC=1
  fi
else
  warn "checkov non installato: salto (brew install checkov)."
fi

# I workflow (UC 0005) non sono "infra Terraform" ma la loro validazione statica
# vive qui: check è l'unico entrypoint di lint del repo lato tooling (#10 H).
info "6/6 actionlint (workflow GitHub Actions)…"
WORKFLOWS_DIR="$INFRA_DIR/../.github/workflows"
if [ ! -d "$WORKFLOWS_DIR" ]; then
  warn "nessun .github/workflows/: salto actionlint."
elif command -v actionlint >/dev/null 2>&1; then
  if (cd "$INFRA_DIR/.." && actionlint); then
    ok "actionlint: workflow validi"
  else
    warn "actionlint FALLITO"; RC=1
  fi
else
  warn "actionlint non installato: salto (brew install actionlint)."
fi

if [ "$RC" -eq 0 ]; then ok "check: tutto verde"; else die "check: problemi rilevati (vedi sopra)"; fi
